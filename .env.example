# ContextKeeper 环境变量配置

# 数据库：默认本地 SQLite，团队版可切换 PostgreSQL + pgvector
# SQLite 示例（个人/本地）：
CK_DATABASE_URL=sqlite:///~/.context-keeper/context_keeper.db
# PostgreSQL 示例（团队共享）：
# CK_DATABASE_URL=postgresql://user:pass@localhost:5432/contextkeeper

# 嵌入模型
CK_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CK_EMBEDDING_DIM=384

# 混合召回权重（0-1）
CK_VECTOR_WEIGHT=0.6
CK_BM25_WEIGHT=0.4

# 记忆陈旧度阈值（天）
CK_MEMORY_STALENESS_DAYS=90

# 团队同步模式：none | git | api
CK_SYNC_MODE=none
CK_SYNC_REMOTE_URL=

# API 服务配置
CK_HOST=127.0.0.1
CK_PORT=8000
